---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import StatusBadge from './StatusBadge.astro';

interface Props {
	project: CollectionEntry<'projects'>;
	index: number;
}

const { project, index } = Astro.props;
const { title, status, date, outcome, tags, hero_asset } = project.data;

const dateLabel = date.toISOString().slice(0, 10);
---

<li class:list={['row', status]} style={`--stagger: ${index * 50}ms`}>
	<a href={`/projects/${project.id}/`} data-project={project.id}>
		{
			hero_asset ? (
				<Image class="thumb" src={hero_asset} alt="" width={160} height={100} />
			) : (
				<div class:list={['thumb', 'tile', status]} aria-hidden="true">
					<span>{title.slice(0, 2)}</span>
				</div>
			)
		}
		<div class="body">
			<div class="head">
				<h3>{title}</h3>
				<StatusBadge status={status} />
			</div>
			<p class="outcome">{outcome}</p>
			<div class="meta">
				<time datetime={dateLabel}>{dateLabel}</time>
				{tags.map((t) => <span class="tag">{t}</span>)}
			</div>
		</div>
	</a>
</li>

<style>
	.row {
		list-style: none;
		border-bottom: 1px solid var(--hairline);
		animation: reveal var(--duration-reveal) var(--ease-out) both;
		animation-delay: var(--stagger);
	}
	@keyframes reveal {
		from {
			opacity: 0;
			transform: translateY(10px);
		}
		to {
			opacity: 1;
			transform: none;
		}
	}
	.row.paused {
		opacity: 0.75;
	}
	a {
		display: flex;
		gap: 1.25rem;
		padding-block: 1.5rem;
		color: inherit;
		text-decoration: none;
	}
	a:hover h3 {
		color: var(--accent);
	}
	.row.dead a:hover h3 {
		color: var(--dead);
	}
	.thumb {
		flex: 0 0 auto;
		width: 160px;
		height: 100px;
		object-fit: cover;
		border: 1px solid var(--hairline);
		border-radius: var(--radius);
	}
	.tile {
		display: grid;
		place-items: center;
		font-family: var(--font-mono);
		font-size: var(--text-lg);
		text-transform: uppercase;
		color: var(--text-dim);
		background: var(--bg-raised);
	}
	.tile.live span {
		color: var(--accent);
	}
	.tile.dead span {
		color: var(--dead);
		filter: saturate(0.6);
	}
	.head {
		display: flex;
		align-items: baseline;
		gap: 0.75rem;
		flex-wrap: wrap;
	}
	h3 {
		font-size: var(--text-md);
		margin: 0;
		transition: color var(--duration-micro) var(--ease-out);
	}
	.outcome {
		color: var(--text-dim);
		max-width: var(--measure);
		margin: 0.35rem 0 0.6rem;
	}
	.meta {
		display: flex;
		gap: 0.6rem;
		flex-wrap: wrap;
		font-family: var(--font-mono);
		font-size: 0.7rem;
		color: var(--text-dim);
	}
	.tag::before {
		content: '#';
		opacity: 0.6;
	}
	@media (max-width: 600px) {
		.thumb {
			width: 96px;
			height: 64px;
		}
	}
</style>

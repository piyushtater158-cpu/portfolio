---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { site } from '../config';

const projects = (await getCollection('projects')).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Base>
	<section class="hero">
		<img
			class="poster"
			src="/constellation.svg"
			alt=""
			width="1200"
			height="675"
			fetchpriority="high"
		/>
		<div class="hero-copy">
			<h1><span class="typed">{site.title}</span><span class="cursor" aria-hidden="true">█</span></h1>
			<p class="tag">GenAI systems developer — building living AI systems for organizations</p>
		</div>
	</section>

	<section class="feed" aria-labelledby="work-heading">
		<h2 id="work-heading"><span class="marker">01</span> WORK</h2>
		{
			projects.length > 0 ? (
				<ul>
					{projects.map((p, i) => (
						<ProjectCard project={p} index={i} />
					))}
				</ul>
			) : (
				<p class="empty">
					<span class="mono">case studies compiling…</span> first entries land
					shortly. Until then, the inbox works: see below.
				</p>
			)
		}
	</section>
</Base>

<style>
	.hero {
		min-height: 60dvh;
		display: grid;
		place-content: center;
		text-align: center;
		position: relative;
	}
	.poster {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: contain;
		opacity: 0.55;
	}
	.hero-copy {
		position: relative;
	}
	h1 {
		margin: 0;
	}
	.cursor {
		color: var(--accent);
		animation: blink 1.1s steps(1) infinite;
	}
	@keyframes blink {
		50% {
			opacity: 0;
		}
	}
	.hero .tag {
		font-family: var(--font-mono);
		font-size: var(--text-sm);
		color: var(--text-dim);
		text-transform: uppercase;
		letter-spacing: 0.08em;
		max-width: 40ch;
		margin-inline: auto;
	}
	.feed {
		padding-block: 3rem;
	}
	h2 {
		font-size: var(--text-base);
		letter-spacing: 0.12em;
		border-bottom: 1px solid var(--hairline);
		padding-bottom: 0.75rem;
	}
	.marker {
		color: var(--accent);
	}
	ul {
		margin: 0;
		padding: 0;
	}
	.empty {
		color: var(--text-dim);
		padding-block: 2rem;
		max-width: var(--measure);
	}
	.empty .mono {
		font-family: var(--font-mono);
		color: var(--text);
	}
</style>
